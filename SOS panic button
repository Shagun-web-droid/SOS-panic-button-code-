#include <ESP8266WiFi.h>
#include <WiFiClientSecure.h>
#include <TinyGPS++.h>
#include <SoftwareSerial.h>

#define LED D2
#define BUZZER D3
#define BUTTON D1

// WiFi credentials
const char* ssid = "Your_WiFi_Name";
const char* password = "Your_WiFi_Password";

// Telegram credentials
const char* botToken = "YOUR_BOT_TOKEN";
const char* chatID = "YOUR_CHAT_ID";

TinyGPSPlus gps;
SoftwareSerial gpsSerial(D7, D8); // RX, TX

void setup() {
  Serial.begin(115200);
  gpsSerial.begin(9600);
  pinMode(LED, OUTPUT);
  pinMode(BUZZER, OUTPUT);
  pinMode(BUTTON, INPUT_PULLUP);

  Serial.println("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected!");
}

void loop() {
  if (digitalRead(BUTTON) == LOW) {
    digitalWrite(LED, HIGH);
    digitalWrite(BUZZER, HIGH);
    delay(1000);
    digitalWrite(BUZZER, LOW);
    Serial.println("SOS Triggered!");

    float lat = 0.0, lon = 0.0;
    unsigned long start = millis();
    while (millis() - start < 10000) {  // read GPS for 10 seconds
      while (gpsSerial.available() > 0) {
        if (gps.encode(gpsSerial.read()) && gps.location.isValid()) {
          lat = gps.location.lat();
          lon = gps.location.lng();
        }
      }
    }

    sendTelegramMessage(lat, lon);

    delay(5000);
    digitalWrite(LED, LOW);
  }
}

void sendTelegramMessage(float lat, float lon) {
  WiFiClientSecure client;
  client.setInsecure(); // skip SSL certificate

  if (!client.connect("api.telegram.org", 443)) {
    Serial.println("Connection to Telegram failed!");
    return;
  }

  String msg = "🚨 *SOS Alert!* Please help!\n";
  msg += "My Location: [Google Maps link](https://maps.google.com/?q=" + String(lat, 6) + "," + String(lon, 6) + ")";
  
  String url = "/bot" + String(botToken) + "/sendMessage?chat_id=" + String(chatID) +
               "&text=" + urlencode(msg) + "&parse_mode=Markdown";

  client.print(String("GET ") + url + " HTTP/1.1\r\n" +
               "Host: api.telegram.org\r\n" +
               "Connection: close\r\n\r\n");

  Serial.println("SOS Message Sent to Telegram!");
}

String urlencode(String str) {
  String encoded = "";
  char c;
  char code0;
  char code1;
  char code2;
  for (int i = 0; i < str.length(); i++) {
    c = str.charAt(i);
    if (isalnum(c)) {
      encoded += c;
    } else {
      encoded += '%';
      code1 = (c >> 4) & 0xF;
      code2 = (c & 0xF);
      code1 += code1 > 9 ? 'A' - 10 : '0';
      code2 += code2 > 9 ? 'A' - 10 : '0';
      encoded += code1;
      encoded += code2;
    }
  }
  return encoded;
}
